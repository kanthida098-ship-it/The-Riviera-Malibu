// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: units
// Document ID: auto-generated
// Fields:
//   - title: string (required) - Listing title
//   - location: string (required) - Unit location
//   - size: string (optional) - Unit size
//   - floor: string (optional) - Floor number
//   - price: string (required) - Unit price
//   - view: string (optional) - Unit view
//   - status: string (required, enum: ['available', 'reserved', 'sold']) - Current status
//   - images: list (optional) - List of image URLs
//   - bedrooms: number (optional) - Number of bedrooms
//   - bathrooms: number (optional) - Number of bathrooms
//   - highlight: string (optional) - Key highlight
//   - type: string (required, enum: ['sale', 'rent']) - Listing type
//   - createdAt: timestamp (optional)
//   - updatedAt: timestamp (optional)
//
// Collection: images
// Document ID: auto-generated
// Fields:
//   - url: string (required) - Image URL
//   - name: string (required) - Original filename
//   - size: number (optional) - File size in bytes
//   - contentType: string (optional) - MIME type
//   - uploadedAt: timestamp (required)
//   - uploadedBy: string (required) - UID of uploader
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kanthida098@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= min &&
             request.resource.data[field].size() <= max;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUnit(data) {
      return hasRequiredFields(['title', 'location', 'price', 'status', 'type']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             data.price is string && data.price.size() > 0 && data.price.size() < 50 &&
             data.status in ['available', 'reserved', 'sold'] &&
             data.type in ['sale', 'rent'] &&
             (!('images' in data) || data.images is list) &&
             (!('bedrooms' in data) || data.bedrooms is number) &&
             (!('bathrooms' in data) || data.bathrooms is number);
    }

    function isValidImage(data) {
      return hasRequiredFields(['url', 'name', 'uploadedAt', 'uploadedBy']) &&
             isValidUrl(data.url) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 255 &&
             data.uploadedAt is timestamp &&
             data.uploadedBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Units collection
    match /units/{unitId} {
      allow read: if true; // Publicly readable for the website
      allow create: if isAdmin() && isValidUnit(request.resource.data);
      allow update: if isAdmin() && isValidUnit(request.resource.data);
      allow delete: if isAdmin();
    }

    // Images collection
    match /images/{imageId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidImage(request.resource.data);
      allow update: if isAdmin() && isValidImage(request.resource.data);
      allow delete: if isAdmin();
    }

    // Users collection (for roles)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

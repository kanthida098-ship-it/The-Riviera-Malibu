rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow anyone to view images (Public Read)
      allow read: if true;
      
      // Only allow the admin to upload or delete images (Secure Write)
      allow write: if request.auth != null && 
                   request.auth.token.email == "kanthida098@gmail.com" && 
                   request.auth.token.email_verified == true;
    }
  }
}
